MES_JWT_SECRET=replace-with-a-strong-secret
MES_JWT_TTL_SECONDS=28800
MES_AUTH_ACCESS_COOKIE_NAME=mes_session
MES_AUTH_REFRESH_COOKIE_NAME=mes_refresh
MES_COOKIE_SECURE=true
MES_LOGIN_MAX_FAILURES=5
MES_LOGIN_LOCKOUT_MINUTES=15
MES_REQUEST_LOG=true
MES_ACCESS_TOKEN_TTL_SECONDS=900
MES_REFRESH_TOKEN_TTL_SECONDS=604800
MES_SESSION_IDLE_TIMEOUT_SECONDS=28800
MES_MAX_ACTIVE_SESSIONS=5

MES_DATA_DRIVER=mysql
MES_MYSQL_HOST=127.0.0.1
MES_MYSQL_PORT=3306
MES_MYSQL_DATABASE=mes_core
MES_MYSQL_USER=mes_user
MES_MYSQL_PASSWORD=replace-with-a-strong-password

